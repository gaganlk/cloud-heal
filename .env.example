# --- CRITICAL PRODUCTION SECRETS ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-key

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-this-to-a-secure-key

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
REDIS_PASSWORD=secure-redis-pass

# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://aiops_user:secure-db-pass@postgres:5432/cloud_healing_db
REDIS_URL=redis://:secure-redis-pass@redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Optional Integrations ---
GEMINI_API_KEY=your-gemini-key
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@gmail.com
